<div class="sta-launcher-sections">
  {{#each sections}}
  <div class="sta-launcher-section">
    {{#if label}}<div class="sta-launcher-section-header">{{label}}</div>{{/if}}
    <div class="sta-launcher-grid" style="grid-template-columns: repeat({{columns}}, 1fr)">
      {{#each items}}
      <button class="sta-launcher-btn" type="button" data-item-id="{{id}}" title="{{label}}" draggable="true">
        <i class="fa-solid {{icon}}"></i>
        <span>{{label}}</span>
      </button>
      {{/each}}
    </div>
  </div>
  {{/each}}
</div>
