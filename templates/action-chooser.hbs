<div class="sta-action-chooser">
  <section class="sta-action-chooser-header">
    <div class="sta-action-chooser-title">
      {{#if canSwitchSet}}
        <select class="sta-action-chooser-title__select">
          {{#each actionSets as |set|}}
            <option value="{{set.id}}" {{#if set.selected}}selected{{/if}}>{{set.label}}</option>
          {{/each}}
        </select>
      {{else}}
        {{actionSetLabel}}
      {{/if}}
    </div>
    <div class="sta-actor-indicator {{#unless hasActor}}sta-actor-indicator--empty{{/unless}}">
      <img class="sta-actor-indicator__img" src="{{actorImg}}" alt="{{actorName}}" />
      {{#if hasActorOptions}}
        <select class="sta-actor-indicator__select">
          {{#unless hasActor}}
            <option value="" selected disabled>{{localize "sta-utils.actionChooser.selectCharacter"}}</option>
          {{/unless}}
          {{#each actorOptions as |actor|}}
            <option value="{{actor.id}}" {{#if actor.selected}}selected{{/if}}>{{actor.name}}</option>
          {{/each}}
        </select>
      {{else}}
        <span class="sta-actor-indicator__name">{{actorName}}</span>
      {{/if}}
    </div>
    {{#if showStarship}}
    <div class="sta-actor-indicator sta-starship-indicator {{#unless hasStarship}}sta-actor-indicator--empty{{/unless}}">
      <img class="sta-starship-indicator__img" src="{{starshipImg}}" alt="{{starshipName}}" />
      {{#if hasStarshipOptions}}
        <select class="sta-starship-indicator__select">
          {{#unless hasStarship}}
            <option value="" selected disabled>{{localize "sta-utils.actionChooser.selectStarship"}}</option>
          {{/unless}}
          {{#each starshipOptions as |ship|}}
            <option value="{{ship.id}}" {{#if ship.selected}}selected{{/if}}>{{ship.name}}</option>
          {{/each}}
        </select>
      {{else}}
        <span class="sta-actor-indicator__name">{{starshipName}}</span>
      {{/if}}
    </div>
    {{/if}}
  </section>

  {{!-- Minor Actions --}}
  {{#if hasMinorActions}}
  <section class="sta-action-chooser-section" data-section="minor">
    <h3>{{localize "sta-utils.actionChooser.minorActions"}}</h3>
    <div class="sta-action-split">
      <div class="sta-action-tabs">
        {{#each minorActions as |action|}}
          <button type="button"
            class="sta-action-tab{{#if action.isSubtle}} sta-action-tab--subtle{{/if}}"
            data-type="minor"
            data-tab-id="{{action.id}}"
            data-action-name="{{action.name}}"
            data-action-desc="{{action.description}}"
            data-action-roll="{{action.rollInfo}}"
            data-action-momentum="{{action.momentumText}}">
            <span class="sta-action-tab__name">{{action.name}}</span>
          </button>
        {{/each}}
      </div>
      <div class="sta-action-detail" data-type="minor">
        <div class="sta-action-detail__empty">{{localize "sta-utils.actionChooser.minorActions"}}</div>
      </div>
    </div>
  </section>
  {{/if}}

  {{!-- Major Actions --}}
  {{#if hasMajorActions}}
  <section class="sta-action-chooser-section" data-section="major">
    <h3>{{localize "sta-utils.actionChooser.majorActions"}}</h3>
    <div class="sta-action-split">
      <div class="sta-action-tabs">
        {{#each majorActions as |action|}}
          <button type="button"
            class="sta-action-tab{{#if action.isSubtle}} sta-action-tab--subtle{{/if}}"
            data-type="major"
            data-tab-id="{{action.id}}"
            data-action-name="{{action.name}}"
            data-action-desc="{{action.description}}"
            data-action-roll="{{action.rollInfo}}"
            data-action-momentum="{{action.momentumText}}">
            <span class="sta-action-tab__name">{{action.name}}</span>
          </button>
        {{/each}}
      </div>
      <div class="sta-action-detail" data-type="major">
        <div class="sta-action-detail__empty">{{localize "sta-utils.actionChooser.majorActions"}}</div>
      </div>
    </div>
  </section>
  {{/if}}

  {{!-- Social Tools --}}
  {{#if hasSocialTools}}
  <section class="sta-action-chooser-section" data-section="social">
    <h3>{{localize "sta-utils.actionChooser.socialTools"}}</h3>
    <div class="sta-action-split">
      <div class="sta-action-tabs">
        {{#each socialTools as |action|}}
          <button type="button"
            class="sta-action-tab{{#if action.isSubtle}} sta-action-tab--subtle{{/if}}"
            data-type="social"
            data-tab-id="{{action.id}}"
            data-action-name="{{action.name}}"
            data-action-desc="{{action.description}}"
            data-action-roll="{{action.rollInfo}}"
            data-action-momentum="{{action.momentumText}}">
            <span class="sta-action-tab__name">{{action.name}}</span>
          </button>
        {{/each}}
      </div>
      <div class="sta-action-detail" data-type="social">
        <div class="sta-action-detail__empty">{{localize "sta-utils.actionChooser.socialTools"}}</div>
      </div>
    </div>
  </section>
  {{/if}}
</div>
