{{!-- LCARS-themed limited view for STA 2e characters.
     Shown to players who don't own the actor.
--}}
<div class="character-sheet sta-lcars {{lcarsSchemeClass}}">
  <div class="split-section">
    <div class="top-left-column">
      <div class="image-field">
        <img class="profile-img" src="{{actor.img}}" alt="{{actor.name}}" data-edit="img" title="{{actor.name}}" />
      </div>
    </div>

    <div class="top-right-column">
      <div class="name-field">
        <label class="title" for="limited-name">{{localize 'sta.actor.character.name'}}</label>
        <input name="name" id="limited-name" class="text-entry" type="text" value="{{actor.name}}" placeholder="{{localize 'sta.actor.character.name'}}" />
      </div>

      <label class="title" for="limited-rank">{{localize 'sta.actor.character.rank'}}</label>
      <input name="system.rank" id="limited-rank" class="text-entry" type="text" value="{{actor.system.rank}}" placeholder="{{localize 'sta.actor.character.rank'}}" />
      {{#if showProseMirror}}
        <div class="title">{{localize 'sta.actor.note.title'}}</div>
        <div class="note2e">
          <prose-mirror
            name="system.notes"
            document-uuid="{{actor.uuid}}"
            value="{{actor.system.notes}}"
            collaborate="true"
            toggled="false"
            {{#unless editable}}disabled{{/unless}}>
            {{{enrichedNotes}}}
          </prose-mirror>
        </div>
      {{/if}}
    </div>
  </div>
</div>
