<section class="sta-settings-form">
  <p class="hint">{{localize "sta-officers-log.settings.acclaimSurvey.editorHint"}}</p>

  <div class="form-group">
    <label>{{localize "sta-officers-log.settings.acclaimSurvey.positiveLabel"}}</label>
    <div class="form-fields">
      <textarea name="positiveQuestionsText" rows="6" style="width:100%" spellcheck="true" placeholder="{{localize "sta-officers-log.settings.acclaimSurvey.positivePlaceholder"}}">{{positiveQuestionsText}}</textarea>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "sta-officers-log.settings.acclaimSurvey.negativeLabel"}}</label>
    <div class="form-fields">
      <textarea name="negativeQuestionsText" rows="6" style="width:100%" spellcheck="true" placeholder="{{localize "sta-officers-log.settings.acclaimSurvey.negativePlaceholder"}}">{{negativeQuestionsText}}</textarea>
    </div>
  </div>

  <footer class="form-footer">
    <button type="submit" class="dialog-button"><i class="fa-solid fa-save"></i> {{localize "sta-officers-log.settings.acclaimSurvey.save"}}</button>
  </footer>
</section>
