<section class="ext-task-tracker-display {{#if @root.options.editable}}editable{{/if}}">
    {{#if trackers}}
        <div class="ext-tracker-list">
            {{#each trackers as |tracker|}}
                <div
                    class="ext-tracker-entry {{#if tracker.editable}}editable{{/if}} {{#if tracker.private}}private{{/if}} {{#if tracker.isConsequence}}consequence{{/if}} {{#if tracker.isTimedChallenge}}timed-challenge{{/if}} {{#unless tracker.visible}}hidden{{/unless}}"
                    data-id="{{tracker.id}}"
                    style="--max: {{tracker.max}}; --filled: {{tracker.value}}; --entry-color: {{tracker.color}}; --entry-background: {{tracker.backgroundColor}}"
                >
                    <div class="ext-tracker-name">
                        <div class="ext-name-row">
                            <span class="value" title="{{tracker.name}}">{{#if tracker.private}}<i class="fas fa-eye-slash"></i> {{/if}}{{tracker.name}}</span>
                        </div>
                        <div class="ext-meta-row">
                            <span class="ext-tracker-stats">
                                {{#if tracker.isTimedChallenge}}
                                    <span class="ext-stat timed" title="Clock Rate"><i class="fa-solid fa-clock"></i>: 2</span>
                                {{else if tracker.isConsequence}}
                                    <span class="ext-stat impact" title="Impact">Impact: {{tracker.impact}}</span>
                                {{else}}
                                    <span class="ext-stat" title="Difficulty">Difficulty: {{tracker.difficulty}}</span>
                                {{/if}}
                                {{#if tracker.resistance}}<span class="ext-stat resistance" title="Resistance">Resist: {{tracker.resistance}}</span>{{/if}}
                            </span>
                            {{#if @root.options.editable}}
                                <div class="ext-tracker-controls">
                                    {{#if tracker.actorId}}
                                        <a data-action="openLinkedActor" title="{{localize "sta-utils.extendedTaskTracker.linkedActor"}}"><i class="fa-solid fa-fw fa-link"></i></a>
                                    {{else}}
                                        {{#unless tracker.isTimedChallenge}}
                                            <a data-action="saveToActor" title="{{localize "sta-utils.extendedTaskTracker.saveToActor"}}"><i class="fa-solid fa-fw fa-floppy-disk"></i></a>
                                        {{/unless}}
                                    {{/if}}
                                    <a data-action="deleteEntry" aria-label="{{localize 'sta-utils.aria.deleteEntry'}}"><i class="fa-solid fa-fw fa-trash" aria-hidden="true"></i></a>
                                    <a data-action="editEntry" aria-label="{{localize 'sta-utils.aria.editEntry'}}"><i class="fa-solid fa-fw fa-edit" aria-hidden="true"></i></a>
                                </div>
                            {{/if}}
                        </div>
                    </div>
                    <div class="ext-tracker-bar graphic" aria-label="{{tracker.name}}" aria-valuemin="0" aria-valuemax="{{tracker.max}}" aria-valuenow="{{tracker.value}}">
                        <div class="ext-tracker-value">{{tracker.value}}/{{tracker.max}}</div>
                        <div class="ext-tracker-slashes">
                            {{#each tracker.rows as |row|}}
                                <div class="ext-tracker-row">
                                    {{#each row}}
                                        <div class="slash {{#if this.filled}}filled{{/if}}"></div>
                                        {{#if this.breakthrough}}
                                            <div class="{{this.breakClass}}" title="{{this.breakthroughLabel}}"></div>
                                        {{/if}}
                                    {{/each}}
                                </div>
                            {{/each}}
                        </div>
                    </div>
                </div>
            {{/each}}
        </div>
    {{/if}}
    {{#if @root.options.editable}}
        <div class="ext-tracker-main-controls">
            <button class="ui-control" data-action="addTracker">
                <i class="fas fa-plus"></i><span class="btn-label"> {{localize "sta-utils.extendedTaskTracker.add"}}</span>
            </button>
            <button class="ui-control breakthrough-btn" data-action="breakthroughMenu">
                <i class="fas fa-bolt"></i><span class="btn-label"> {{localize "sta-utils.extendedTaskTracker.breakthrough"}}</span>
            </button>
            <button class="ui-control clear-all-btn" data-action="clearAll">
                <i class="fas fa-trash"></i><span class="btn-label"> {{localize "sta-utils.extendedTaskTracker.clearAll"}}</span>
            </button>
        </div>
    {{/if}}
</section>
