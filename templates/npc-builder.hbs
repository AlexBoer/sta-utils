<div class="npc-builder">

  {{!-- ── Step: Info ──────────────────────────────────────────────── --}}
  <div class="npc-builder-panel{{#if stepPanels.info}} active{{/if}}" data-panel="info">
    <h3 class="npc-builder-panel-title">Character Info</h3>

    <div class="npc-builder-field-row">
      <label class="npc-builder-label">Name <span class="npc-required">*</span></label>
      <input class="npc-builder-input" type="text" name="npc-name" value="{{name}}"
        placeholder="NPC Name" autofocus>
    </div>

    <div class="npc-builder-field-row">
      <label class="npc-builder-label">NPC Type</label>
      <div class="npc-type-radios">
        <label class="npc-radio-label{{#if isMinor}} active{{/if}}">
          <input type="radio" name="npcType" value="minor" {{#if isMinor}}checked{{/if}}>
          Minor
        </label>
        <label class="npc-radio-label{{#if isNotable}} active{{/if}}">
          <input type="radio" name="npcType" value="notable" {{#if isNotable}}checked{{/if}}>
          Notable
        </label>
      </div>
    </div>

    <div class="npc-builder-field-row">
      <label class="npc-builder-label">
        Species <span class="npc-hint">(becomes a trait)</span>
      </label>
      {{#if speciesFromCatalog}}
      <div class="npc-species-combobox">
        <input class="npc-builder-input" type="text" name="species" value="{{species}}"
          placeholder="Search species…" autocomplete="off" role="combobox"
          aria-expanded="false" aria-autocomplete="list">
        <ul class="npc-species-dropdown" role="listbox">
          {{#each speciesList}}
          <li class="npc-species-option" role="option" data-value="{{name}}">
            {{name}}{{#if hasTalent}} <span class="npc-species-talent-badge" title="Has species talent">✦</span>{{/if}}
          </li>
          {{/each}}
        </ul>
      </div>
      {{else}}
      <input class="npc-builder-input" type="text" name="species" value="{{species}}"
        placeholder="e.g. Vulcan">
      {{/if}}
    </div>

    <div class="npc-builder-field-row">
      <label class="npc-builder-label">
        Role / Career <span class="npc-hint">(becomes a trait)</span>
      </label>
      <input class="npc-builder-input" type="text" name="role" value="{{role}}"
        placeholder="e.g. Security Officer">
    </div>
  </div>

  {{!-- ── Step: Attributes ──────────────────────────────────────── --}}
  <div class="npc-builder-panel{{#if stepPanels.attributes}} active{{/if}}" data-panel="attributes">
    <h3 class="npc-builder-panel-title">Assign Attributes</h3>
    <p class="npc-builder-hint">Drag numbers from the pool onto attribute rows. Drag a placed chip back to the pool to un-assign it.</p>

    <div class="npc-chip-pool{{#if attrPoolEmpty}} done{{/if}}" id="npc-attr-pool">
      {{#each availableAttrChips}}
      <div class="npc-chip" draggable="true" data-value="{{this}}" data-source-key="">{{this}}</div>
      {{/each}}
      {{#if attrPoolEmpty}}<span class="npc-pool-done"><i class="fa-solid fa-check"></i> All assigned</span>{{/if}}
    </div>

    {{#if showBonusColumn}}
    <p class="npc-builder-hint npc-bonus-hint">Species bonus:
      {{#if needsAttributeBonusSelection}}choose 3 attributes to receive <strong>+1</strong> each{{else}}attributes marked <strong>+1</strong> include your species bonus{{/if}}
    </p>
    {{/if}}

    <div class="npc-slot-grid{{#if showBonusColumn}} has-bonus-col{{/if}}">
      {{#each attributeSlots}}
      <div class="npc-slot-row">
        <span class="npc-slot-label">{{label}}</span>
        <div class="npc-drop-zone{{#unless value}} empty{{/unless}}" data-key="{{key}}">
          {{#if value}}
          <div class="npc-chip npc-chip--assigned" draggable="true"
            data-value="{{value}}" data-source-key="{{key}}">{{value}}</div>
          {{else}}
          <span class="npc-slot-placeholder">—</span>
          {{/if}}
        </div>
        {{#if ../showBonusColumn}}
        <div class="npc-bonus-col">
          {{#if fixedBonus}}
          <span class="npc-bonus-fixed">+1</span>
          {{else if choiceBonus}}
          <input type="checkbox" class="npc-bonus-attr-cb" value="{{key}}"
            {{#if choiceBonus.selected}}checked{{/if}}
            {{#if choiceBonus.disabled}}disabled{{/if}}>
          {{/if}}
        </div>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>

  {{!-- ── Step: Departments ──────────────────────────────────────── --}}
  <div class="npc-builder-panel{{#if stepPanels.departments}} active{{/if}}" data-panel="departments">
    <h3 class="npc-builder-panel-title">Assign Departments</h3>
    <p class="npc-builder-hint">Assign all chips. Departments without a chip will default to 0.</p>

    <div class="npc-chip-pool{{#if discPoolEmpty}} done{{/if}}" id="npc-disc-pool">
      {{#each availableDiscChips}}
      <div class="npc-chip" draggable="true" data-value="{{this}}" data-source-key="">{{this}}</div>
      {{/each}}
      {{#if discPoolEmpty}}<span class="npc-pool-done"><i class="fa-solid fa-check"></i> All assigned</span>{{/if}}
    </div>

    <div class="npc-slot-grid">
      {{#each disciplineSlots}}
      <div class="npc-slot-row">
        <span class="npc-slot-label">{{label}}</span>
        <div class="npc-drop-zone{{#unless value}} empty{{/unless}}" data-key="{{key}}">
          {{#if value}}
          <div class="npc-chip npc-chip--assigned" draggable="true"
            data-value="{{value}}" data-source-key="{{key}}">{{value}}</div>
          {{else}}
          <span class="npc-slot-placeholder">0</span>
          {{/if}}
        </div>
      </div>
      {{/each}}
    </div>
  </div>

  {{!-- ── Step: Details (Notable only) ────────────────────────── --}}
  <div class="npc-builder-panel{{#if stepPanels.details}} active{{/if}}" data-panel="details">
    <h3 class="npc-builder-panel-title">Focuses &amp; Value</h3>

    <div class="npc-builder-section-label">
      Focuses <span class="npc-hint">(up to 3, optional)</span>
    </div>
    {{#each focusList}}
    <div class="npc-builder-field-row">
      <div class="npc-field-rand-wrap">
        {{#if ../hasFocusSuggestions}}
        <div class="npc-focus-combobox npc-species-combobox">
          <input class="npc-builder-input" type="text" value="{{value}}"
            placeholder="Focus {{num}}" autocomplete="off">
          <ul class="npc-suggestion-dropdown npc-species-dropdown" role="listbox">
            {{#each ../focusSuggestions}}
            <li class="npc-suggestion-option npc-species-option" role="option">{{this}}</li>
            {{/each}}
          </ul>
        </div>
        {{else}}
        <input class="npc-builder-input npc-focus-input" type="text" value="{{value}}"
          placeholder="Focus {{num}}">
        {{/if}}
        <button class="npc-field-random-btn npc-builder-btn npc-builder-btn--ghost" type="button"
          title="Pick random" data-action="random-focus" data-index="{{@index}}"><i class="fa-solid fa-shuffle"></i></button>
      </div>
    </div>
    {{/each}}

    <div class="npc-builder-section-label npc-section-gap">
      Value <span class="npc-hint">(optional)</span>
    </div>
    <div class="npc-builder-field-row">
      <div class="npc-field-rand-wrap">
        {{#if hasValueSuggestions}}
        <div class="npc-value-combobox npc-species-combobox">
          <input class="npc-builder-input" type="text" value="{{value}}"
            placeholder="e.g. Duty and Loyalty" autocomplete="off">
          <ul class="npc-suggestion-dropdown npc-species-dropdown" role="listbox">
            {{#each valueSuggestions}}
            <li class="npc-suggestion-option npc-species-option" role="option">{{this}}</li>
            {{/each}}
          </ul>
        </div>
        {{else}}
        <input class="npc-builder-input npc-value-input" type="text" value="{{value}}"
          placeholder="e.g. Duty and Loyalty">
        {{/if}}
        <button class="npc-field-random-btn npc-builder-btn npc-builder-btn--ghost" type="button"
          title="Pick random" data-action="random-value"><i class="fa-solid fa-shuffle"></i></button>
      </div>
    </div>
  </div>

  {{!-- ── Step: Special Rules ────────────────────────────────── --}}
  <div class="npc-builder-panel{{#if (lookup stepPanels 'special-rules')}} active{{/if}}" data-panel="special-rules">
    <h3 class="npc-builder-panel-title">Special Rules</h3>

    {{#if specialRulesAvailable}}
      <p class="npc-builder-hint">Preview talents and add them to Custom Talents.</p>
      <div class="npc-builder-field-row" style="margin-bottom:0.5rem;">
        <input class="npc-builder-input npc-special-rules-search" type="text"
          value="{{specialRulesSearch}}" placeholder="Search talents...">
      </div>
      <div class="npc-builder-field-row" style="display:flex;flex-direction:row;align-items:center;gap:1rem;flex-wrap:nowrap;margin-bottom:0.6rem;">
        <label class="npc-builder-hint" style="display:flex;align-items:center;gap:0.35rem;">
          <input class="npc-special-rules-filter-npc" type="checkbox" {{#if specialRulesNpcOnly}}checked{{/if}}>
          NPC Talents Only
        </label>
        <label class="npc-builder-hint" style="display:flex;align-items:center;gap:0.35rem;">
          <input class="npc-special-rules-filter-requirements" type="checkbox" {{#if specialRulesRequirementsOnly}}checked{{/if}}>
          Meets Requirements Only
        </label>
      </div>

    {{#if hasSpecialRulesMatches}}
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;align-items:start;">
        <ul class="npc-equip-list" style="margin:0;">
          {{#each specialRulesItems}}
          <li class="npc-equip-item npc-special-rule-row{{#if previewActive}} active{{/if}}"
            data-uuid="{{uuid}}"
            style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;cursor:pointer;">
            <div class="npc-equip-label" style="flex:1;min-width:0;">
              <div style="display:flex;align-items:center;gap:0.45rem;min-width:0;">
                <img class="npc-equip-img" src="{{img}}" alt="">
                <span class="npc-equip-name">{{name}}</span>
                {{#if isNpcType}}
                <span class="npc-hint" style="white-space:nowrap;">NPC</span>
                {{/if}}
              </div>
            </div>
            <div style="display:flex;gap:0.35rem;align-items:center;">
              <button class="npc-builder-btn npc-builder-btn--ghost npc-special-rule-add-btn"
                type="button" data-uuid="{{uuid}}" data-name="{{name}}" title="Add to custom talents">
                <i class="fa-solid fa-plus"></i>
              </button>
            </div>
          </li>
          {{/each}}
        </ul>

        <div class="npc-custom-talent" style="margin-bottom:0;">
          <div class="npc-builder-section-label" style="margin-top:0;">Talent Preview</div>
          {{#if specialRulePreview}}
          <div class="npc-equip-label" style="margin-bottom:0.5rem;">
            <img class="npc-equip-img" src="{{specialRulePreview.img}}" alt="">
            <span class="npc-equip-name">{{specialRulePreview.name}}</span>
          </div>
          {{#if specialRulePreview.requirementLabel}}
          <div class="npc-builder-hint" style="margin-bottom:0.5rem;">{{specialRulePreview.requirementLabel}}</div>
          {{/if}}
          <div class="npc-builder-input" style="padding:0.5rem;max-height:16rem;overflow:auto;">
            {{{specialRulePreview.description}}}
          </div>
          {{else}}
          <p class="npc-builder-hint">Select a talent to preview its description.</p>
          {{/if}}
        </div>
      </div>
    {{else}}
      {{#if specialRulesTotalCount}}
      <p class="npc-builder-hint">No talents match the current filters.</p>
      {{else}}
      <p class="npc-builder-hint">No items found in the special rules compendium.</p>
      {{/if}}
    {{/if}}
    {{else}}
    <p class="npc-builder-hint">No compendium configured. Add talents manually or from templates below.</p>
    {{/if}}

    <div class="npc-builder-section-label npc-section-gap">Talent Templates</div>
    <p class="npc-builder-hint">Insert a template, then customize it below.</p>
    <div class="npc-loadout-presets" style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:0.35rem;">
      {{#each talentTemplates}}
      <button class="npc-loadout-btn npc-talent-template-btn" style="width:100%;" data-template-index="{{@index}}" type="button">{{name}}</button>
      {{/each}}
    </div>

    <div class="npc-builder-section-label npc-section-gap">Custom Talents</div>
    {{#if customTalents.length}}
    {{#each customTalents}}
    <div class="npc-custom-talent npc-builder-field-row" style="flex-direction:column;gap:4px;margin-bottom:0.6rem;">
      <div style="display:flex;justify-content:flex-end;">
        <button class="npc-builder-btn npc-builder-btn--ghost npc-custom-talent-remove" type="button" data-talent-index="{{@index}}" title="Remove talent">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
      <input class="npc-builder-input npc-custom-talent-name" type="text"
        value="{{name}}" placeholder="Talent name (optional)">
      <textarea class="npc-builder-input npc-custom-talent-desc"
        placeholder="Talent description (optional)" rows="2"
        style="resize:vertical;font-family:inherit;font-size:inherit;">{{description}}</textarea>
    </div>
    {{/each}}
    {{else}}
    <p class="npc-builder-hint">No custom talents yet.</p>
    {{/if}}

    <button class="npc-builder-btn npc-builder-btn--ghost npc-custom-talent-add" type="button">
      <i class="fa-solid fa-plus"></i> Add Custom Talent
    </button>
  </div>

  {{!-- ── Step: Equipment ──────────────────────────────────────── --}}
  <div class="npc-builder-panel{{#if stepPanels.equipment}} active{{/if}}" data-panel="equipment">
    <h3 class="npc-builder-panel-title">Equipment</h3>

    {{#if equipmentAvailable}}
      {{#if equipmentItems.length}}
      <p class="npc-builder-hint">Select items to add to the NPC.</p>
      {{#if equipmentLoadouts.length}}
      <div class="npc-loadout-presets">
        {{#each equipmentLoadouts}}
        <button class="npc-loadout-btn{{#if active}} active{{/if}}"
          data-loadout="{{@index}}" type="button">{{name}}</button>
        {{/each}}
      </div>
      {{/if}}
      <ul class="npc-equip-list">
        {{#each equipmentItems}}
        <li class="npc-equip-item">
          <label class="npc-equip-label">
            <input class="npc-equip-checkbox" type="checkbox" value="{{uuid}}"
              {{#if checked}}checked{{/if}}>
            <img class="npc-equip-img" src="{{img}}" alt="">
            <span class="npc-equip-name">{{name}}</span>
          </label>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="npc-builder-hint">No items found in the equipment compendium.</p>
      {{/if}}
    {{else}}
    <div class="npc-equip-placeholder">
      <i class="fa-solid fa-box-archive"></i>
      <p>Equipment compendium not configured.</p>
      <p class="npc-equip-placeholder-sub">Set <code>EQUIPMENT_COMPENDIUM_UUID</code> in
        <code>scripts/npc-builder/npc-builder-data.mjs</code> to enable this step.</p>
    </div>
    {{/if}}
  </div>

  {{!-- ── Footer ──────────────────────────────────────────────── --}}
  <div class="npc-builder-footer">
    <div class="npc-builder-footer-left">
      {{#unless isFirstStep}}
      <button class="npc-builder-back npc-builder-btn npc-builder-btn--ghost">
        <i class="fa-solid fa-chevron-left"></i> Back
      </button>
      {{/unless}}
      <button class="npc-builder-randomize npc-builder-btn npc-builder-btn--ghost" type="button"
        title="Randomize this step">
        <i class="fa-solid fa-shuffle"></i>
      </button>
    </div>

    <span class="npc-builder-step-label">{{stepLabel}}</span>

    <div class="npc-builder-footer-right">
      {{#if isLastStep}}
      <button class="npc-builder-create npc-builder-btn npc-builder-btn--primary"
        {{#unless canProceed}}disabled{{/unless}}>
        <i class="fa-solid fa-user-plus"></i> Create NPC
      </button>
      {{else}}
      <button class="npc-builder-next npc-builder-btn npc-builder-btn--primary"
        {{#unless canProceed}}disabled{{/unless}}>
        Next <i class="fa-solid fa-chevron-right"></i>
      </button>
      {{/if}}
    </div>
  </div>

</div>
