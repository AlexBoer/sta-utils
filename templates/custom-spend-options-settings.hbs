<section class="sta-settings-form">
  <p class="hint">{{localize "sta-officers-log.settings.customSpendOptions.editorHint"}}</p>

  <div class="form-group">
    <label>{{localize "sta-officers-log.settings.customSpendOptions.awardsLabel"}}</label>
    <p class="hint">{{localize "sta-officers-log.settings.customSpendOptions.awardsHint"}}</p>
    <div class="form-fields">
      <textarea name="customAwardsText" rows="5" style="width:100%" spellcheck="true" placeholder="{{localize "sta-officers-log.settings.customSpendOptions.awardsPlaceholder"}}">{{customAwardsText}}</textarea>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "sta-officers-log.settings.customSpendOptions.acclaimLabel"}}</label>
    <p class="hint">{{localize "sta-officers-log.settings.customSpendOptions.acclaimHint"}}</p>
    <div class="form-fields">
      <textarea name="customAcclaimText" rows="5" style="width:100%" spellcheck="true" placeholder="{{localize "sta-officers-log.settings.customSpendOptions.acclaimPlaceholder"}}">{{customAcclaimText}}</textarea>
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "sta-officers-log.settings.customSpendOptions.reprimandLabel"}}</label>
    <p class="hint">{{localize "sta-officers-log.settings.customSpendOptions.reprimandHint"}}</p>
    <div class="form-fields">
      <textarea name="customReprimandText" rows="5" style="width:100%" spellcheck="true" placeholder="{{localize "sta-officers-log.settings.customSpendOptions.reprimandPlaceholder"}}">{{customReprimandText}}</textarea>
    </div>
  </div>

  <footer class="form-footer">
    <button type="submit" class="dialog-button"><i class="fa-solid fa-save"></i> {{localize "sta-officers-log.settings.customSpendOptions.save"}}</button>
  </footer>
</section>
